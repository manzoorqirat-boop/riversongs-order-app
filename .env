# ── RESTEL Environment Variables ──────────────────────────

# Master DB — stores hotels, users, superadmin accounts
MASTER_MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/restel_master?retryWrites=true&w=majority

# Tenant DB base — same cluster, different DB per hotel
TENANT_MONGO_BASE_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net

# JWT secret — change this in production!
JWT_SECRET=restel-super-secret-change-me-in-production

# Server port
PORT=3000